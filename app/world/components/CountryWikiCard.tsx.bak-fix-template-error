function MacroChart({ facts }: { facts: WikiFact[] }) {
  const inflation = findFact(facts, ["inflation", "inflation ( cpi )"]);
  const unemployment = findFact(facts, ["unemployment"]);
  const gdpGrowth = findFact(facts, ["gdp growth"]);
  const youthUnemployment = findFact(facts, ["youth unemployment"]);

  const data = [
    inflation
      ? { name: "Inflation", value: parsePercent(inflation.value) }
      : null,
    unemployment
      ? { name: "Unemployment", value: parsePercent(unemployment.value) }
      : null,
    gdpGrowth
      ? { name: "GDP growth", value: parsePercent(gdpGrowth.value) }
      : null,
    youthUnemployment
      ? { name: "Youth unemployment", value: parsePercent(youthUnemployment.value) }
      : null,
  ].filter((x): x is { name: string; value: number } => !!x && x.value !== null);

  if (!data.length) return null;

  return (
    <div className="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
      <div className="text-xs font-black uppercase tracking-wide text-slate-900">
        Macro pressure indicators
      </div>
      <div className="mt-3 h-[230px]">
        <ResponsiveContainer width="100%" height="100%">
          <BarChart data={data}>
            <CartesianGrid strokeDasharray="3 3" vertical={false} />
            <XAxis dataKey="name" tick={{ fontSize: 11 }} />
            <YAxis tick={{ fontSize: 11 }} tickFormatter={(v) => ${v}%} />
            <Tooltip
              formatter={(value: any) => [
                ${Number(value).toFixed(1)}%,
                "Rate",
              ]}
            />
            <Bar dataKey="value" radius={[10, 10, 0, 0]} fill="#6366f1" />
          </BarChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}

function TradeChart({ facts }: { facts: WikiFact[] }) {
  const exportsFact = findFact(facts, ["exports"]);
  const importsFact = findFact(facts, ["imports"]);

  const exportValue = parseMoneyToBillion(exportsFact?.value);
  const importValue = parseMoneyToBillion(importsFact?.value);

  const data = [
    exportValue !== null ? { name: "Exports", value: Number(exportValue.toFixed(2)) } : null,
    importValue !== null ? { name: "Imports", value: Number(importValue.toFixed(2)) } : null,
  ].filter((x): x is { name: string; value: number } => !!x);

  if (!data.length) return null;

  return (
    <div className="rounded-2xl border border-emerald-200 bg-white p-3 shadow-sm">
      <div className="text-xs font-black uppercase tracking-wide text-emerald-800">
        External trade size
      </div>
      <div className="mt-3 h-[230px]">
        <ResponsiveContainer width="100%" height="100%">
          <BarChart data={data}>
            <CartesianGrid strokeDasharray="3 3" vertical={false} />
            <XAxis dataKey="name" tick={{ fontSize: 12 }} />
            <YAxis tick={{ fontSize: 11 }} tickFormatter={(v) => $B} />
            <Tooltip
              formatter={(value: any) => [
                $B,
                "Value",
              ]}
            />
            <Bar dataKey="value" radius={[10, 10, 0, 0]} fill="#10b981" />
          </BarChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}

