function disIsNumericOnly(value: unknown) {
  const text = cleanHtml(value);
  return /^[<>~≈\s\d,.\-–—]+$/.test(text);
}

function disIsDeathCountCell(value: unknown) {
  const text = cleanHtml(value);
  const key = keyOf(text);

  if (!text) return true;
  if (key.includes("death toll") || key.includes("deaths") || key.includes("fatalities")) return true;

  const numeric = Number(text.replace(/[^\d.-]/g, ""));

  if (disIsNumericOnly(text) && Number.isFinite(numeric) && Math.abs(numeric) > new Date().getUTCFullYear() + 10) {
    return true;
  }

  if (/^\s*\d{1,3}(?:,\d{3})+(?:\s*[-–—]\s*\d{1,3}(?:,\d{3})+)?\s*$/.test(text)) {
    return true;
  }

  return false;
}

function disParseYearFromDateCell(value: unknown) {
  const raw = cleanHtml(value);
  if (!raw) return null;

  if (disIsDeathCountCell(raw) && !/\b(BC|BCE|AD|CE)\b/i.test(raw)) {
    return null;
  }

  const bestYear = disExtractBestYear(raw);

  if (bestYear === null) return null;

  return {
    startYear: bestYear,
    endYear: bestYear,
  };
}
function disFindDateCell(cells: { raw: string; text: string }[]) {
  // Search from right to left because date/year columns are usually near the end.
  for (let index = cells.length - 1; index >= 0; index -= 1) {
    const text = cleanHtml(cells[index]?.text ?? "");
    const key = keyOf(text);

    if (!text) continue;
    if (["rank", "death toll", "deaths", "fatalities", "event", "name", "location", "country"].includes(key)) continue;

    const years = disParseYearFromDateCell(text);
    if (!years) continue;

    return {
      index,
      years,
    };
  }

  return null;
}

function disDisasterKeywordScore(value: unknown) {
  const key = keyOf(value);

  const keywords = [
    "earthquake",
    "flood",
    "cyclone",
    "hurricane",
    "typhoon",
    "tsunami",
    "eruption",
    "volcanic",
    "volcano",
    "famine",
    "pandemic",
    "epidemic",
    "plague",
    "influenza",
    "cholera",
    "drought",
    "blizzard",
    "hailstorm",
    "landslide",
    "avalanche",
    "fire",
    "wildfire",
    "heat wave",
    "disaster",
    "storm",
    "tornado",
  ];

  return keywords.reduce((score, keyword) => score + (key.includes(keyword) ? 4 : 0), 0);
}

function disPickTitleCell(cells: { raw: string; text: string }[], dateIndex: number) {
  let best: { index: number; cell: { raw: string; text: string }; score: number } | null = null;

  for (let index = 0; index < cells.length; index += 1) {
    if (index === dateIndex) continue;

    const cell = cells[index];
    const text = cleanHtml(cell?.text ?? "");
    const key = keyOf(text);

    if (!text || !key) continue;
    if (["rank", "date", "year", "location", "country", "region", "death toll", "deaths", "fatalities"].includes(key)) continue;
    if (disIsDeathCountCell(text)) continue;

    const article = firstArticle(cell.raw);
    const articleTitle = cleanHtml(article?.title || "");
    const articleKey = keyOf(articleTitle);

    if (articleTitle && disIsDeathCountCell(articleTitle)) continue;
    if (/^\d+$/.test(articleKey)) continue;

    let score = 0;

    if (articleTitle) score += 6;
    if (index === 1) score += 3;
    if (index === 0) score += 1;

    score += disDisasterKeywordScore(text);
    score += disDisasterKeywordScore(articleTitle);

    if (text.length > 3 && text.length < 120) score += 1;

    if (!best || score > best.score) {
      best = {
        index,
        cell,
        score,
      };
    }
  }

  return best;
}

function disCleanTitle(value: unknown) {
  return cleanHtml(value)
    .replace(/^\d+\.\s*/, "")
    .replace(/^\d{1,4}\s*[-–—]\s*/, "")
    .replace(/\s+/g, " ")
    .trim();
}

function parseDisasterTableRows(html: string, source: SourcePage) {
