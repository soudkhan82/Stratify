export async function GET(req: Request) {
  try {
    const { searchParams } = new URL(req.url);

    const segment = (searchParams.get("segment") || "revolutions") as SegmentKey;
    const sourceKey = searchParams.get("sourceKey") || "revolutions-rebellions";

    if (segment === "disasters") {
      return await handleDisastersOnly(req, segment, sourceKey);
    }

    if (segment === "civilizations") {
      return await handleCivilizationsOnly(req, segment, sourceKey);
    }

    if (segment === "leaders") {
      return await handleLeadersOnly(req, segment, sourceKey);
    }

    // IMPORTANT:
    // The page sends from/to and pageSize.
    // Previous broken route expected fromYear/toYear and rows.
    const from = toInt(searchParams.get("from") || searchParams.get("fromYear"), null);
    const to = toInt(searchParams.get("to") || searchParams.get("toYear"), null);
    const page = Math.max(1, toInt(searchParams.get("page"), 1) ?? 1);
    const pageSize = Math.max(
      1,
      Math.min(1000, toInt(searchParams.get("pageSize") || searchParams.get("rows"), 25) ?? 25)
    );
    const query = searchParams.get("q") || searchParams.get("search") || "";

    const sources = getSources(segment, sourceKey);

    const groups = await Promise.all(
      sources.map(async (source) => {
        const html = await disFetchWikiHtml(source.page);
        return [...parseTableRows(html, source), ...parseListItems(html, source)];
      })
    );

    const allRecords = dedupe(groups.flat()).sort((a, b) => {
      const ay = getRecordYear(a) ?? 999999;
      const by = getRecordYear(b) ?? 999999;
      if (ay !== by) return ay - by;
      return a.title.localeCompare(b.title);
    });

    const rangedRecords = filterByRange(allRecords, from, to);
    const searchedRecords = filterBySearch(rangedRecords, query);

    const total = searchedRecords.length;
    const start = (page - 1) * pageSize;
    const events = searchedRecords.slice(start, start + pageSize);
    const hasMore = start + pageSize < total;
    const buckets = buildBuckets(rangedRecords, from, to);

    return NextResponse.json(
      {
        ok: true,
        segment,
        sourceKey,
        sourceLabel: sources.map((s) => s.label).join(", "),
        sourceTitle: sources.map((s) => s.label).join(", "),
        page,
        pageSize,
        events,
        records: events,
        data: events,
        items: events,
        total,
        hasMore,
        buckets,
        activeRange:
          from !== null && to !== null
            ? {
                from: Math.min(from, to),
                to: Math.max(from, to),
              }
            : null,
        warning: null,
        meta: {
          route: "source-records",
          fixedRangeParams: "from/to",
          fixedPaginationParams: "page/pageSize",
          hardcodedEvents: false,
          fetchedRecords: allRecords.length,
          rangedRecords: rangedRecords.length,
        },
      },
      {
        headers: {
          "Cache-Control": "no-store, no-cache, must-revalidate",
        },
      }
    );
  } catch (error) {
    console.error("History source-records error:", error);

    return NextResponse.json(
      {
        ok: false,
        events: [],
        records: [],
        data: [],
        items: [],
        total: 0,
        hasMore: false,
        buckets: [],
        warning: error instanceof Error ? error.message : "Unable to load history records.",
      },
      { status: 500 }
    );
  }
}



















