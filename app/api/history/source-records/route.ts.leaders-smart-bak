/* STRATIFY_DISASTER_YEAR_NORMALIZER_FIX
   Disasters-only: fixes dates like "November 1, 1755" where day number was parsed as year.
*/
const DIS_HTML_CACHE = new Map<string, string>();

function disExtractBestYear(value: unknown) {
  const text = cleanHtml(value)
    .replace(/,/g, "")
    .replace(/[−‐-‒–—]/g, "-")
    .replace(/\s+/g, " ")
    .trim();

  if (!text) return null;

  const currentYear = new Date().getUTCFullYear() + 10;

  const monthLike =
    /\b(january|february|march|april|may|june|july|august|september|october|november|december)\b/i.test(text);

  // Month-style dates: "November 1 1755" => choose 1755, never 1.
  if (monthLike) {
    const fullYears = [...text.matchAll(/\b(\d{3,4})\s*(BC|BCE|AD|CE)?\b/gi)]
      .map((match) => {
        const n = Number(match[1]);
        if (!Number.isFinite(n)) return null;

        const era = String(match[2] || "").toUpperCase();
        const year = era === "BC" || era === "BCE" ? -Math.abs(n) : n;

        if (year === 0) return null;
        if (year > currentYear) return null;

        return year;
      })
      .filter((year): year is number => typeof year === "number");

    return fullYears[0] ?? null;
  }

  // Prefer explicit 3/4 digit years for disaster records.
  const explicitYears = [...text.matchAll(/\b(\d{3,4})\s*(BC|BCE|AD|CE)?\b/gi)]
    .map((match) => {
      const n = Number(match[1]);
      if (!Number.isFinite(n)) return null;

      const era = String(match[2] || "").toUpperCase();
      const year = era === "BC" || era === "BCE" ? -Math.abs(n) : n;

      if (year === 0) return null;
      if (year > currentYear) return null;

      return year;
    })
    .filter((year): year is number => typeof year === "number");

  if (explicitYears.length) return explicitYears[0];

  // Allow ancient dates only if an era is clearly present.
  const ancient = text.match(/\b(\d{1,4})\s*(BC|BCE)\b/i);

  if (ancient) {
    const n = Number(ancient[1]);
    if (Number.isFinite(n) && n > 0) return -Math.abs(n);
  }

  return null;
}

function disNormalizeRecordYear(record: HistoryRecord): HistoryRecord | null {
  const title = cleanHtml(record.title);
  const description = cleanHtml(record.description);

  const titleKey = keyOf(title);

  // Remove citation/reference garbage from pandemic/disaster pages.
  if (
    !titleKey ||
    titleKey === "doi" ||
    titleKey === "local" ||
    titleKey.includes("journal") ||
    titleKey.includes("university") ||
    titleKey.includes("retrieved") ||
    titleKey.includes("archived") ||
    title.startsWith("^") ||
    title.startsWith("[")
  ) {
    return null;
  }

  let bestYear = disExtractBestYear(title);

  if (bestYear === null) {
    bestYear = disExtractBestYear(description);
  }

  if (bestYear === null) {
    const current = Number(record.startYear ?? record.year);
    if (Number.isFinite(current) && Math.abs(current) > 31) {
      bestYear = Math.trunc(current);
    }
  }

  if (bestYear === null) return null;

  return {
    ...record,
    year: bestYear,
    startYear: bestYear,
    endYear: bestYear,
  };
}

async function disFetchWikiHtml(page: string) {
  const cacheKey = page;

  const cached = DIS_HTML_CACHE.get(cacheKey);
  if (cached) return cached;

  try {
    const html = await fetchWikiHtml(page);
    DIS_HTML_CACHE.set(cacheKey, html);
    return html;
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);

    // Wikipedia sometimes returns 429 during rapid dev refreshes.
    // Wait briefly and retry once for disaster sources only.
    if (message.includes("429")) {
      await new Promise((resolve) => setTimeout(resolve, 1200));

      const html = await fetchWikiHtml(page);
      DIS_HTML_CACHE.set(cacheKey, html);
      return html;
    }

    throw error;
  }
}
async function disFetchRecords(sourceKey: string) {
  const sources = disSources(sourceKey);

  const groups = await Promise.all(
    sources.map(async (source) => {
      const html = await disFetchWikiHtml(source.page);

      return [
        ...parseDisasterTableRows(html, source),
        ...parseDisasterListItems(html, source),
      ];
    })
  );

  return dedupe(
    groups
      .flat()
      .map(disNormalizeRecordYear)
      .filter((record): record is HistoryRecord => Boolean(record))
  ).sort((a, b) => {
    const ay = getRecordYear(a) ?? 999999;
    const by = getRecordYear(b) ?? 999999;

    if (ay !== by) return ay - by;

    return a.title.localeCompare(b.title);
  });
}

async function handleDisastersOnly(req: Request, segment: SegmentKey, sourceKey: string) {
  const { searchParams } = new URL(req.url);

  const from = toInt(searchParams.get("from") || searchParams.get("fromYear"), null);
  const to = toInt(searchParams.get("to") || searchParams.get("toYear"), null);

  const page = Math.max(1, toInt(searchParams.get("page"), 1) ?? 1);
  const pageSize = Math.max(
    1,
    Math.min(1000, toInt(searchParams.get("pageSize") || searchParams.get("rows"), 25) ?? 25)
  );

  const query = searchParams.get("q") || searchParams.get("search") || "";

  let allRecords: HistoryRecord[] = [];

  try {
    allRecords = await disFetchRecords(sourceKey);
  } catch (error) {
    console.error("Disasters parser failed:", error);

    return NextResponse.json(
      {
        ok: true,
        segment,
        sourceKey,
        sourceLabel: disSourceLabel(sourceKey),
        sourceTitle: disSourceLabel(sourceKey),
        page,
        pageSize,
        events: [],
        records: [],
        data: [],
        items: [],
        total: 0,
        hasMore: false,
        buckets: [],
        activeRange:
          from !== null && to !== null
            ? { from: Math.min(from, to), to: Math.max(from, to) }
            : null,
        warning:
          error instanceof Error
            ? `Disasters source failed: ${error.message}`
            : "Disasters source failed.",
      },
      {
        headers: {
          "Cache-Control": "no-store, no-cache, must-revalidate",
        },
      }
    );
  }

  const rangedRecords = filterByRange(allRecords, from, to);
  const searchedRecords = filterBySearch(rangedRecords, query);

  const total = searchedRecords.length;
  const start = (page - 1) * pageSize;
  const events = searchedRecords.slice(start, start + pageSize);
  const hasMore = start + pageSize < total;
  const buckets = buildBuckets(rangedRecords, from, to);

  return NextResponse.json(
    {
      ok: true,
      segment,
      sourceKey,
      sourceLabel: disSourceLabel(sourceKey),
      sourceTitle: disSourceLabel(sourceKey),
      page,
      pageSize,
      events,
      records: events,
      data: events,
      items: events,
      total,
      hasMore,
      buckets,
      activeRange:
        from !== null && to !== null
          ? { from: Math.min(from, to), to: Math.max(from, to) }
          : null,
      warning: total ? null : "No disaster records found for the selected timeframe.",
      meta: {
        route: "source-records",
        branch: "disasters-safe-parser",
        hardcodedEvents: false,
        fetchedRecords: allRecords.length,
        rangedRecords: rangedRecords.length,
      },
    },
    {
      headers: {
        "Cache-Control": "no-store, no-cache, must-revalidate",
      },
    }
  );
}
