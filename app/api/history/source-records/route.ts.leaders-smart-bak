function decodeEntities(value: string) {
  return String(value ?? "")
    .replace(/&nbsp;/gi, " ")
    .replace(/&#160;/gi, " ")
    .replace(/&amp;/gi, "&")
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&apos;/gi, "'")
    .replace(/&lt;/gi, "<")
    .replace(/&gt;/gi, ">");
}

function cleanHtml(value: unknown) {
  return decodeEntities(String(value ?? ""))
    .replace(/<style[\s\S]*?<\/style>/gi, " ")
    .replace(/<script[\s\S]*?<\/script>/gi, " ")
    .replace(/<sup[\s\S]*?<\/sup>/gi, " ")
    .replace(/<span[^>]*class="mw-editsection"[\s\S]*?<\/span>/gi, " ")
    .replace(/<br\s*\/?>/gi, " | ")
    .replace(/<\/li>/gi, " | ")
    .replace(/<\/p>/gi, " | ")
    .replace(/<\/div>/gi, " | ")
    .replace(/<[^>]+>/g, " ")
    .replace(/\[\s*\d+\s*\]/g, " ")
    .replace(/\s*\|\s*/g, " | ")
    .replace(/\s+/g, " ")
    .trim();
}

function keyOf(value: unknown) {
  return cleanHtml(value)
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function toInt(value: string | null, fallback: number | null) {
  if (value === null || value === "") return fallback;
  const n = Number(value);
  return Number.isFinite(n) ? Math.trunc(n) : fallback;
}

function applyEra(year: number, era?: string | null) {
  const e = String(era ?? "").toUpperCase();
  return e === "BC" || e === "BCE" ? -Math.abs(year) : year;
}

function expandShortEndYear(start: number, endRaw: string) {
  const end = Number(endRaw);
  if (!Number.isFinite(end)) return start;

  const digits = endRaw.length;
  const startDigits = String(Math.abs(start)).length;

  if (start > 0 && digits < startDigits) {
    const factor = Math.pow(10, digits);
    let expanded = Math.floor(start / factor) * factor + end;
    if (expanded < start) expanded += factor;
    return expanded;
  }

  return end;
}

function parseYearRange(value: string) {
  const text = cleanHtml(value)
    .replace(/,/g, "")
    .replace(/[−‐-‒–—]/g, "-");

  const range = text.match(
    /(?:c\.?\s*)?(\d{1,4})\s*(BC|BCE|AD|CE)?\s*(?:-|to|until|through)\s*(?:c\.?\s*)?(\d{1,4}|present|ongoing)\s*(BC|BCE|AD|CE)?/i
  );

  if (range) {
    const startEra = range[2];
    const endRaw = range[3];
    const endEra = range[4] || startEra;

    const startYear = applyEra(Number(range[1]), startEra);
    const endYear = /present|ongoing/i.test(endRaw)
      ? new Date().getUTCFullYear()
      : applyEra(expandShortEndYear(startYear, endRaw), endEra);

    if (!Number.isFinite(startYear)) return null;

    return {
      startYear,
      endYear: Number.isFinite(endYear) ? endYear : startYear,
    };
  }

  const single = text.match(/(?:^|[^\d])(?:c\.?\s*)?(\d{1,4})\s*(BC|BCE|AD|CE)?(?:$|[^\d])/i);
  if (!single) return null;

  const year = applyEra(Number(single[1]), single[2]);
  if (!Number.isFinite(year)) return null;

  return {
    startYear: year,
    endYear: year,
  };
}

function startsWithYear(value: string) {
  return /^\s*(?:c\.?\s*)?\d{1,4}\s*(?:BC|BCE|AD|CE)?/i.test(cleanHtml(value));
}

function extractCells(rowHtml: string) {
  const cells: { raw: string; text: string }[] = [];
  const re = /<(td|th)\b[^>]*>([\s\S]*?)<\/\1>/gi;
  let match: RegExpExecArray | null;

  while ((match = re.exec(rowHtml))) {
    const raw = match[2] ?? "";
    const text = cleanHtml(raw);
    if (text) cells.push({ raw, text });
  }

  return cells;
}

function firstArticle(rawHtml: string) {
  const re = /<a\b[^>]*href="\/wiki\/([^"#?:]+)"[^>]*>([\s\S]*?)<\/a>/gi;
  let match: RegExpExecArray | null;

  while ((match = re.exec(rawHtml))) {
    const href = decodeURIComponent(match[1] ?? "");
    const title = cleanHtml(match[2] ?? "");

    if (!href || !title) continue;

    if (
      href.startsWith("File:") ||
      href.startsWith("Help:") ||
      href.startsWith("Special:") ||
      href.startsWith("Category:") ||
      href.startsWith("Template:") ||
      href.startsWith("Wikipedia:") ||
      href.startsWith("Portal:")
    ) {
      continue;
    }

    return {
      title,
      url: `${WIKI_ORIGIN}/wiki/${encodeURIComponent(href).replace(/%2F/g, "/")}`,
    };
  }

  return null;
}

function makeRecord(args: {
  source: SourcePage;
  title: string;
  startYear: number;
  endYear: number;
  description: string;
  articleUrl: string | null;
}): HistoryRecord {
  return {
    qid: null,
    title: cleanHtml(args.title),
    description: cleanHtml(args.description),
    type: args.source.type,
    year: args.startYear,
    startYear: args.startYear,
    endYear: args.endYear,
    articleUrl: args.articleUrl,
    source: `Wikipedia - ${args.source.label}`,
  };
}

function parseTableRows(html: string, source: SourcePage) {
  const output: HistoryRecord[] = [];
  const rows = html.match(/<tr\b[\s\S]*?<\/tr>/gi) ?? [];

  for (const rowHtml of rows) {
    const cells = extractCells(rowHtml);
    if (cells.length < 2) continue;

    const firstYears = parseYearRange(cells[0]?.text ?? "");
    const secondYears = parseYearRange(cells[1]?.text ?? "");

    let startYear: number | null = null;
    let endYear: number | null = null;
    let titleIndex = -1;

    if (
      cells.length >= 3 &&
      firstYears &&
      secondYears &&
      startsWithYear(cells[0].text) &&
      startsWithYear(cells[1].text)
    ) {
      startYear = firstYears.startYear;
      endYear = secondYears.startYear;
      titleIndex = 2;
    } else if (firstYears && startsWithYear(cells[0].text)) {
      startYear = firstYears.startYear;
      endYear = firstYears.endYear;
      titleIndex = 1;
    } else if (secondYears && startsWithYear(cells[1].text)) {
      startYear = secondYears.startYear;
      endYear = secondYears.endYear;
      titleIndex = 0;
    }

    // STRATIFY_CIVILIZATION_EXISTED_COLUMN_FIX
    // Civilization/state tables usually use:
    // State | Capital | Type | Existed
    // Example: Old Kingdom of Egypt | Memphis | Kingdom | 2686 BC - 2181 BC
    if (
      (startYear === null || endYear === null || titleIndex < 0) &&
      source.type === "EMPIRE / CIVILIZATION"
    ) {
      const existedIndexes = [
        3,
        cells.length - 1,
        4,
        2,
      ].filter((index, pos, arr) => index >= 0 && index < cells.length && arr.indexOf(index) === pos);

      for (const index of existedIndexes) {
        const years = parseYearRange(cells[index]?.text ?? "");

        if (years) {
          startYear = years.startYear;
          endYear = years.endYear;
          titleIndex = 0;
          break;
        }
      }
    }

    if (startYear === null || endYear === null || titleIndex < 0) continue;

    const titleCell = cells[titleIndex];
    if (!titleCell) continue;

    const article = firstArticle(titleCell.raw);
    const title = article?.title || titleCell.text;
    const titleKey = keyOf(title);

    if (leaderFakeTitleFix(title)) continue;

    if (
      !titleKey ||
      ["date", "event", "result", "conflict", "name of conflict", "leader", "state"].includes(titleKey)
    ) {
      continue;
    }

    const description = cells
      .filter((_, index) => index !== titleIndex)
      .map((cell) => cell.text)
      .filter(Boolean)
      .slice(0, 7)
      .join(" | ");

    output.push(
      makeRecord({
        source,
        title,
        startYear,
        endYear,
        description,
        articleUrl: article?.url ?? null,
      })
    );
  }

  return output;
}

function fallbackTitleFromListText(text: string) {
  const cleaned = cleanHtml(text)
    .replace(/^\*?\s*(?:c\.?\s*)?\d{1,4}\s*(?:BC|BCE|AD|CE)?\s*(?:[-–—]\s*(?:c\.?\s*)?\d{1,4}\s*(?:BC|BCE|AD|CE)?)?\s*[:;,-]?\s*/i, "")
    .replace(/^the\s+/i, "")
    .trim();

  return cleaned.split(/[.;|]/)[0]?.trim() || cleaned.slice(0, 90);
}

function parseListItems(html: string, source: SourcePage) {
  const output: HistoryRecord[] = [];
  const items = html.match(/<li\b[^>]*>[\s\S]*?<\/li>/gi) ?? [];

  for (const raw of items) {
    const text = cleanHtml(raw);
    if (!text || text.length < 8) continue;
    if (!startsWithYear(text)) continue;

    const years = parseYearRange(text);
    if (!years) continue;

    const article = firstArticle(raw);
    const title = article?.title || fallbackTitleFromListText(text);
    const titleKey = keyOf(title);

    if (
      !titleKey ||
      titleKey.includes("isbn") ||
      titleKey.includes("citation needed") ||
      ["edit", "main article", "see also", "references", "external links"].includes(titleKey)
    ) {
      continue;
    }

    output.push(
      makeRecord({
        source,
        title,
        startYear: years.startYear,
        endYear: years.endYear,
        description: text,
        articleUrl: article?.url ?? null,
      })
    );
  }

  return output;
}

function dedupe(records: HistoryRecord[]) {
  const seen = new Set<string>();
  const output: HistoryRecord[] = [];

  for (const record of records) {
    const key = `${record.startYear}|${record.endYear}|${keyOf(record.title)}`;
    if (seen.has(key)) continue;
    seen.add(key);
    output.push(record);
  }

  return output;
}

function getRecordYear(record: HistoryRecord) {
  const year = record.startYear ?? record.year ?? record.endYear;
  return Number.isFinite(Number(year)) ? Math.trunc(Number(year)) : null;
}

function filterByRange(records: HistoryRecord[], from: number | null, to: number | null) {
  if (from === null || to === null) return records;

  const start = Math.min(from, to);
  const end = Math.max(from, to);

  return records.filter((record) => {
    const year = getRecordYear(record);
    return year !== null && year >= start && year <= end;
  });
}

function filterBySearch(records: HistoryRecord[], query: string) {
  const q = keyOf(query);
  if (!q) return records;

  const tokens = q.split(" ").filter(Boolean);

  return records.filter((record) => {
    const haystack = keyOf(
      [
        record.title,
        record.description,
        record.type,
        record.source,
        record.startYear,
        record.endYear,
        record.articleUrl,
      ].join(" ")
    );

    return haystack.includes(q) || tokens.every((token) => haystack.includes(token));
  });
}

function fmtYear(year: number) {
  return year < 0 ? `${Math.abs(year)} BC` : String(year);
}

function buildBuckets(records: HistoryRecord[], from: number | null, to: number | null): Bucket[] {
  const years = records
    .map(getRecordYear)
    .filter((year): year is number => year !== null);

  if (from === null || to === null) {
    if (!years.length) return [];
    from = Math.min(...years);
    to = Math.max(...years);
  }

  const start = Math.min(from, to);
  const end = Math.max(from, to);
  const span = Math.max(1, end - start + 1);
  const bucketCount = Math.min(10, span);
  const buckets: Bucket[] = [];

  for (let i = 0; i < bucketCount; i += 1) {
    const bucketFrom = start + Math.floor((i * span) / bucketCount);
    const bucketTo = start + Math.floor(((i + 1) * span) / bucketCount) - 1;

    buckets.push({
      bucket: bucketFrom,
      from: bucketFrom,
      to: Math.max(bucketFrom, bucketTo),
      label:
        bucketFrom === bucketTo
          ? fmtYear(bucketFrom)
          : `${fmtYear(bucketFrom)}-${fmtYear(Math.max(bucketFrom, bucketTo))}`,
      count: 0,
      pct: 0,
    });
  }

  for (const record of records) {
    const year = getRecordYear(record);
    if (year === null || year < start || year > end) continue;

    const index = Math.min(
      bucketCount - 1,
      Math.floor(((year - start) * bucketCount) / span)
    );

    buckets[index].count += 1;
  }

  const maxCount = Math.max(0, ...buckets.map((bucket) => bucket.count));

  return buckets.map((bucket) => ({
    ...bucket,
    pct: maxCount
      ? Math.max(bucket.count > 0 ? 7 : 0, Math.round((bucket.count / maxCount) * 100))
      : 0,
  }));
}

async function fetchWikiHtml(page: string) {
  const url = new URL(`${WIKI_ORIGIN}/w/api.php`);
  url.searchParams.set("action", "parse");
  url.searchParams.set("format", "json");
  url.searchParams.set("origin", "*");
  url.searchParams.set("prop", "text");
  url.searchParams.set("page", decodeURIComponent(page));

  const response = await fetch(url.toString(), {
    headers: {
      Accept: "application/json",
      "User-Agent": "Stratify-History-Module/1.0",
    },
    cache: "no-store",
  });

  if (!response.ok) {
    throw new Error(`Wikipedia fetch failed for ${page}: ${response.status}`);
  }

  const json = await response.json();
  return String(json?.parse?.text?.["*"] ?? "");
}

function getSources(segment: SegmentKey, sourceKey: string) {
