type CivToken = {
  raw: string;
  value: number;
  isCentury: boolean;
  era: string;
};

function civNormalizeDateText(value: unknown) {
  return cleanHtml(value)
    .replace(/,/g, "")
    .replace(/[−‐-‒–—]/g, "-")
    .replace(/\s+/g, " ")
    .trim();
}

function civEra(value: string | undefined, fallback = "AD") {
  const era = String(value || fallback || "AD").toUpperCase();
  if (era === "BCE") return "BC";
  if (era === "CE") return "AD";
  if (era === "BC" || era === "AD") return era;
  return fallback;
}

function civCenturyToYear(century: number, era: string, position: "start" | "end") {
  if (era === "BC") {
    return position === "start"
      ? -(century * 100)
      : -((century - 1) * 100 + 1);
  }

  return position === "start"
    ? (century - 1) * 100 + 1
    : century * 100;
}

function civTokenToYear(token: CivToken, position: "start" | "end", fallbackEra: string) {
  const era = civEra(token.era, fallbackEra);

  if (token.isCentury) {
    return civCenturyToYear(token.value, era, position);
  }

  return era === "BC" ? -Math.abs(token.value) : token.value;
}

function civParseYearRange(value: unknown) {
  const text = civNormalizeDateText(value);

  if (!text || !/\d|present|ongoing/i.test(text)) return null;

  const tokenRegex =
    /(?:c\.?\s*)?(?:(\d{1,2})(?:st|nd|rd|th)\s*centur(?:y|ies)|(\d{1,4}))\s*(BC|BCE|AD|CE)?|present|ongoing/gi;

  const tokens: CivToken[] = [];
  let match: RegExpExecArray | null;

  while ((match = tokenRegex.exec(text))) {
    const raw = match[0] || "";

    if (/present|ongoing/i.test(raw)) {
      tokens.push({
        raw,
        value: new Date().getUTCFullYear(),
        isCentury: false,
        era: "AD",
      });
      continue;
    }

    const century = match[1];
    const year = match[2];
    const era = match[3] || "";

    if (century) {
      tokens.push({
        raw,
        value: Number(century),
        isCentury: true,
        era,
      });
    } else if (year) {
      tokens.push({
        raw,
        value: Number(year),
        isCentury: false,
        era,
      });
    }
  }

  if (!tokens.length) return null;

  const first = tokens[0];
  const second = tokens[1] || tokens[0];

  const laterEra =
    second.era ||
    first.era ||
    tokens.find((token) => token.era)?.era ||
    "AD";

  const startYear = civTokenToYear(first, "start", civEra(laterEra));
  const endYear = civTokenToYear(second, "end", civEra(laterEra));

  if (!Number.isFinite(startYear) || !Number.isFinite(endYear)) return null;

  return {
    startYear: Math.min(startYear, endYear),
    endYear: Math.max(startYear, endYear),
  };
}

function civFindYearCell(cells: { raw: string; text: string }[]) {
  for (let index = 0; index < cells.length; index += 1) {
    const text = civNormalizeDateText(cells[index]?.text ?? "");
    const years = civParseYearRange(text);

    if (!years) continue;

    const looksLikeDateCell =
      /\d/.test(text) &&
      (
        /bc|bce|ad|ce|century|centuries|present|ongoing/i.test(text) ||
        /[-]|to|until|through/i.test(text)
      );

    if (looksLikeDateCell || index >= 2) {
      return {
        index,
        years,
      };
    }
  }

  return null;
}

function civPickTitleCell(cells: { raw: string; text: string }[], yearIndex: number) {
  const preferredIndexes = [0, 1, 2, 3].filter(
    (index, pos, arr) =>
      index >= 0 &&
      index < cells.length &&
      index !== yearIndex &&
      arr.indexOf(index) === pos
  );

  for (const index of preferredIndexes) {
    const text = cleanHtml(cells[index]?.text ?? "");
    const key = keyOf(text);

    if (
      text &&
      key &&
      !["date", "period", "existed", "capital", "type", "state", "notes"].includes(key) &&
      !civParseYearRange(text)
    ) {
      return {
        index,
        cell: cells[index],
      };
    }
  }

  return null;
}

function civRecordOverlaps(record: HistoryRecord, from: number, to: number) {
  const rangeStart = Math.min(from, to);
  const rangeEnd = Math.max(from, to);

  const start = Number(record.startYear ?? record.year);
  const end = Number(record.endYear ?? record.startYear ?? record.year);

  if (!Number.isFinite(start)) return false;

  const safeEnd = Number.isFinite(end) ? end : start;

  return start <= rangeEnd && safeEnd >= rangeStart;
}

function civFilterByOverlap(records: HistoryRecord[], from: number | null, to: number | null) {
  if (from === null || to === null) return records;
  return records.filter((record) => civRecordOverlaps(record, from, to));
}

function civBuildBuckets(records: HistoryRecord[], from: number | null, to: number | null): Bucket[] {
  if (from === null || to === null) {
    return buildBuckets(records, from, to);
  }

  const start = Math.min(from, to);
  const end = Math.max(from, to);
  const span = Math.max(1, end - start + 1);
  const bucketCount = Math.min(10, span);
  const buckets: Bucket[] = [];

  for (let i = 0; i < bucketCount; i += 1) {
    const bucketFrom = start + Math.floor((i * span) / bucketCount);
    const bucketTo = start + Math.floor(((i + 1) * span) / bucketCount) - 1;

    buckets.push({
      bucket: bucketFrom,
      from: bucketFrom,
      to: Math.max(bucketFrom, bucketTo),
      label:
        bucketFrom === bucketTo
          ? fmtYear(bucketFrom)
          : `${fmtYear(bucketFrom)}-${fmtYear(Math.max(bucketFrom, bucketTo))}`,
      count: 0,
      pct: 0,
    });
  }

  for (const record of records) {
    for (const bucket of buckets) {
      if (civRecordOverlaps(record, bucket.from, bucket.to)) {
        bucket.count += 1;
      }
    }
  }

  const maxCount = Math.max(0, ...buckets.map((bucket) => bucket.count));

  return buckets.map((bucket) => ({
    ...bucket,
    pct: maxCount
      ? Math.max(bucket.count > 0 ? 7 : 0, Math.round((bucket.count / maxCount) * 100))
      : 0,
  }));
}

function parseCivilizationTableRows(html: string, source: SourcePage) {
  const output: HistoryRecord[] = [];
  const rows = html.match(/<tr\b[\s\S]*?<\/tr>/gi) ?? [];

  for (const rowHtml of rows) {
    const cells = extractCells(rowHtml);
    if (cells.length < 2) continue;

    const yearCell = civFindYearCell(cells);
    if (!yearCell) continue;

    const titlePick = civPickTitleCell(cells, yearCell.index);
    if (!titlePick) continue;

    const article = firstArticle(titlePick.cell.raw);
    const title = article?.title || titlePick.cell.text;
    const titleKey = keyOf(title);

    if (
      !titleKey ||
      ["name", "state", "civilization", "empire", "kingdom", "period", "region"].includes(titleKey)
    ) {
      continue;
    }

    const description = cells
      .map((cell) => cell.text)
      .filter(Boolean)
      .slice(0, 8)
      .join(" | ");

    output.push(
      makeRecord({
        source,
        title,
        startYear: yearCell.years.startYear,
        endYear: yearCell.years.endYear,
        description,
        articleUrl: article?.url ?? null,
      })
    );
  }

  return output;
}

function parseCivilizationListItems(html: string, source: SourcePage) {
  const output: HistoryRecord[] = [];
  const items = html.match(/<li\b[^>]*>[\s\S]*?<\/li>/gi) ?? [];

  for (const raw of items) {
    const text = cleanHtml(raw);
    if (!text || text.length < 8) continue;

    const years = civParseYearRange(text);
    if (!years) continue;

    const article = firstArticle(raw);
    const title = article?.title || fallbackTitleFromListText(text);
    const titleKey = keyOf(title);

    if (
      !titleKey ||
      titleKey.includes("isbn") ||
      titleKey.includes("citation needed") ||
      ["edit", "main article", "see also", "references", "external links"].includes(titleKey)
    ) {
      continue;
    }

    output.push(
      makeRecord({
        source,
        title,
        startYear: years.startYear,
        endYear: years.endYear,
        description: text,
        articleUrl: article?.url ?? null,
      })
    );
  }

  return output;
}

async function civFetchRecords(sourceKey: string) {
  const sources = civSources(sourceKey);

  const groups = await Promise.all(
    sources.map(async (source) => {
      const html = await fetchWikiHtml(source.page);

      return [
        ...parseCivilizationTableRows(html, source),
        ...parseCivilizationListItems(html, source),
      ];
    })
  );

  return dedupe(groups.flat()).sort((a, b) => {
    const ay = getRecordYear(a) ?? 999999;
    const by = getRecordYear(b) ?? 999999;

    if (ay !== by) return ay - by;

    return a.title.localeCompare(b.title);
  });
}

async function handleCivilizationsOnly(req: Request, segment: SegmentKey, sourceKey: string) {
  const { searchParams } = new URL(req.url);

  const explicitFrom = toInt(searchParams.get("from") || searchParams.get("fromYear"), null);
  const explicitTo = toInt(searchParams.get("to") || searchParams.get("toYear"), null);

  const defaultRange = civDefaultRange(sourceKey);

  const from = explicitFrom ?? defaultRange.from;
  const to = explicitTo ?? defaultRange.to;

  const page = Math.max(1, toInt(searchParams.get("page"), 1) ?? 1);
  const pageSize = Math.max(
    1,
    Math.min(1000, toInt(searchParams.get("pageSize") || searchParams.get("rows"), 25) ?? 25)
  );

  const query = searchParams.get("q") || searchParams.get("search") || "";

  let allRecords: HistoryRecord[] = [];

  try {
    allRecords = await civFetchRecords(sourceKey);
  } catch (error) {
    console.error("Civilizations Wikipedia parser failed:", error);

    return NextResponse.json(
      {
        ok: true,
        segment,
        sourceKey,
        sourceLabel: civSourceLabel(sourceKey),
        sourceTitle: civSourceLabel(sourceKey),
        page,
        pageSize,
        events: [],
        records: [],
        data: [],
        items: [],
        total: 0,
        hasMore: false,
        buckets: [],
        activeRange: {
          from: Math.min(from, to),
          to: Math.max(from, to),
        },
        warning:
          error instanceof Error
            ? `Civilizations source failed: ${error.message}`
            : "Civilizations source failed.",
      },
      {
        headers: {
          "Cache-Control": "no-store, no-cache, must-revalidate",
        },
      }
    );
  }

  const rangedRecords = civFilterByOverlap(allRecords, from, to);
  const searchedRecords = filterBySearch(rangedRecords, query);

  const total = searchedRecords.length;
  const start = (page - 1) * pageSize;
  const events = searchedRecords.slice(start, start + pageSize);
  const hasMore = start + pageSize < total;
  const buckets = civBuildBuckets(rangedRecords, from, to);

  return NextResponse.json(
    {
      ok: true,
      segment,
      sourceKey,
      sourceLabel: civSourceLabel(sourceKey),
      sourceTitle: civSourceLabel(sourceKey),
      page,
      pageSize,
      events,
      records: events,
      data: events,
      items: events,
      total,
      hasMore,
      buckets,
      activeRange: {
        from: Math.min(from, to),
        to: Math.max(from, to),
      },
      warning: total ? null : "No civilization records found for the selected timeframe.",
      meta: {
        route: "source-records",
        branch: "civilizations-wikipedia-overlap-parser",
        hardcodedEvents: false,
        fetchedRecords: allRecords.length,
        rangedRecords: rangedRecords.length,
      },
    },
    {
      headers: {
        "Cache-Control": "no-store, no-cache, must-revalidate",
      },
    }
  );
}
