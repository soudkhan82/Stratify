import { NextResponse } from "next/server";

export const runtime = "nodejs";
export const dynamic = "force-dynamic";
export const revalidate = 0;

type WikiFact = {
  group?: string | null;
  label?: string | null;
  value?: string | null;
};

type WikiSection = {
  title?: string;
  paragraphs?: string[];
};

type WikiPagePayload = {
  ok: boolean;
  title?: string;
  displayTitle?: string;
  description?: string;
  extract?: string;
  pageUrl?: string | null;
  thumbnailUrl?: string | null;
  facts?: WikiFact[];
  highlights?: WikiFact[];
  sections?: WikiSection[];
  error?: string;
};

const WIKI_ORIGIN = "https://en.wikipedia.org";
const WIKI_API = `${WIKI_ORIGIN}/w/api.php`;
const WIKI_SUMMARY = `${WIKI_ORIGIN}/api/rest_v1/page/summary`;

const ISO_TO_COUNTRY: Record<string, string> = {
  AFG: "Afghanistan",
  ALB: "Albania",
  DZA: "Algeria",
  ARG: "Argentina",
  AUS: "Australia",
  AUT: "Austria",
  BGD: "Bangladesh",
  BEL: "Belgium",
  BRA: "Brazil",
  CAN: "Canada",
  CHN: "China",
  DEU: "Germany",
  EGY: "Egypt",
  FRA: "France",
  GBR: "United Kingdom",
  IND: "India",
  IDN: "Indonesia",
  IRN: "Iran",
  IRQ: "Iraq",
  ITA: "Italy",
  JPN: "Japan",
  MYS: "Malaysia",
  MEX: "Mexico",
  NLD: "Netherlands",
  PAK: "Pakistan",
  RUS: "Russia",
  SAU: "Saudi Arabia",
  TUR: "Turkey",
  USA: "United States",
  ZAF: "South Africa",
};

function decodeEntities(value: string) {
  return String(value ?? "")
    .replace(/&nbsp;/gi, " ")
    .replace(/&#160;/gi, " ")
    .replace(/&amp;/gi, "&")
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&apos;/gi, "'")
    .replace(/&lt;/gi, "<")
    .replace(/&gt;/gi, ">")
    .replace(/&#(\d+);/g, (_, n) => String.fromCharCode(Number(n)))
    .replace(/&#x([0-9a-f]+);/gi, (_, n) =>
      String.fromCharCode(parseInt(n, 16)),
    );
}

function cleanHtml(value: unknown) {
  return decodeEntities(String(value ?? ""))
    .replace(/<style[\s\S]*?<\/style>/gi, " ")
    .replace(/<script[\s\S]*?<\/script>/gi, " ")
    .replace(/<sup[\s\S]*?<\/sup>/gi, " ")
    .replace(/<span[^>]*class="mw-editsection"[\s\S]*?<\/span>/gi, " ")
    .replace(/<br\s*\/?>/gi, " | ")
    .replace(/<\/li>/gi, " | ")
    .replace(/<\/p>/gi, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/\[\s*\d+\s*\]/g, " ")
    .replace(/\s*\|\s*/g, " | ")
    .replace(/\s+/g, " ")
    .trim();
}

function cleanText(value: unknown) {
  return cleanHtml(value)
    .normalize("NFKC")
    .replace(/\uFEFF/g, "")
    .replace(/[\u0000-\u001F\u007F-\u009F]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function wikiTitleForUrl(title: string) {
  return encodeURIComponent(cleanText(title).replace(/\s+/g, "_")).replace(
    /%2F/g,
    "/",
  );
}

async function fetchJson(url: string, timeoutMs = 9000) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), timeoutMs);

  try {
    const res = await fetch(url, {
      cache: "no-store",
      signal: controller.signal,
      headers: {
        Accept: "application/json",
        "User-Agent": "Stratify-Country-Profile/1.0",
      },
    });

    if (!res.ok) {
      throw new Error(`Wikipedia request failed: ${res.status}`);
    }

    return await res.json();
  } finally {
    clearTimeout(timer);
  }
}

async function searchWikiTitle(query: string) {
  const url = new URL(WIKI_API);
  url.searchParams.set("action", "query");
  url.searchParams.set("format", "json");
  url.searchParams.set("origin", "*");
  url.searchParams.set("list", "search");
  url.searchParams.set("srlimit", "1");
  url.searchParams.set("srsearch", cleanText(query));

  const json = await fetchJson(url.toString());
  const title = cleanText(json?.query?.search?.[0]?.title);

  if (!title) {
    throw new Error(`No Wikipedia page found for ${query}`);
  }

  return title;
}

async function fetchSummary(title: string) {
  const normalizedTitle = cleanText(title);
  const directUrl = `${WIKI_SUMMARY}/${wikiTitleForUrl(normalizedTitle)}?redirect=true`;

  try {
    const json = await fetchJson(directUrl);

    const pageTitle = cleanText(json?.title || normalizedTitle);
    const displayTitle = cleanText(json?.displaytitle || json?.title || pageTitle);
    const extract = cleanText(json?.extract);

    if (!extract) {
      throw new Error(`No extract available for ${normalizedTitle}`);
    }

    return {
      title: pageTitle,
      displayTitle,
      description: cleanText(json?.description),
      extract,
      pageUrl: json?.content_urls?.desktop?.page || `${WIKI_ORIGIN}/wiki/${wikiTitleForUrl(pageTitle)}`,
      thumbnailUrl: json?.thumbnail?.source || json?.originalimage?.source || null,
    };
  } catch {
    const searchedTitle = await searchWikiTitle(normalizedTitle);
    const json = await fetchJson(
      `${WIKI_SUMMARY}/${wikiTitleForUrl(searchedTitle)}?redirect=true`,
    );

    const pageTitle = cleanText(json?.title || searchedTitle);
    const displayTitle = cleanText(json?.displaytitle || json?.title || pageTitle);
    const extract = cleanText(json?.extract);

    if (!extract) {
      throw new Error(`No extract available for ${searchedTitle}`);
    }

    return {
      title: pageTitle,
      displayTitle,
      description: cleanText(json?.description),
      extract,
      pageUrl: json?.content_urls?.desktop?.page || `${WIKI_ORIGIN}/wiki/${wikiTitleForUrl(pageTitle)}`,
      thumbnailUrl: json?.thumbnail?.source || json?.originalimage?.source || null,
    };
  }
}

async function fetchParsedHtml(title: string) {
  const url = new URL(WIKI_API);
  url.searchParams.set("action", "parse");
  url.searchParams.set("format", "json");
  url.searchParams.set("origin", "*");
  url.searchParams.set("redirects", "true");
  url.searchParams.set("prop", "text");
  url.searchParams.set("page", cleanText(title));

  const json = await fetchJson(url.toString());

  if (json?.error) {
    throw new Error(cleanText(json.error.info || "Wikipedia parse error"));
  }

  return String(json?.parse?.text?.["*"] ?? "");
}

function extractInfoboxFacts(html: string, group: string) {
  const facts: WikiFact[] = [];
  const table =
    html.match(/<table\b[^>]*class="[^"]*\binfobox\b[^"]*"[\s\S]*?<\/table>/i)?.[0] ||
    "";

  if (!table) return facts;

  const rows = table.match(/<tr\b[\s\S]*?<\/tr>/gi) || [];

  for (const row of rows) {
    const th = row.match(/<th\b[^>]*>([\s\S]*?)<\/th>/i)?.[1];
    const td = row.match(/<td\b[^>]*>([\s\S]*?)<\/td>/i)?.[1];

    if (!th || !td) continue;

    const label = cleanText(th)
      .replace(/^\W+/, "")
      .replace(/\s+/g, " ")
      .trim();

    const value = cleanText(td)
      .replace(/\s+/g, " ")
      .replace(/\s+\|\s+/g, " | ")
      .trim();

    if (!label || !value) continue;
    if (label.length > 100 || value.length > 2500) continue;

    const badLabel = label.toLowerCase();
    if (
      badLabel.includes("wikimedia") ||
      badLabel.includes("coordinates") ||
      badLabel === "website"
    ) {
      continue;
    }

    facts.push({
      group,
      label,
      value,
    });
  }

  return facts.slice(0, 120);
}

function extractParagraphs(html: string, max = 4) {
  const paragraphs: string[] = [];
  const matches = html.match(/<p\b[^>]*>[\s\S]*?<\/p>/gi) || [];

  for (const p of matches) {
    const text = cleanText(p);

    if (!text || text.length < 70) continue;
    if (/^This article/i.test(text)) continue;
    if (/coordinates/i.test(text) && text.length < 160) continue;

    paragraphs.push(text);

    if (paragraphs.length >= max) break;
  }

  return paragraphs;
}

function extractSections(html: string) {
  const sections: WikiSection[] = [];

  const sectionRe =
    /<h([23])\b[^>]*>([\s\S]*?)<\/h\1>([\s\S]*?)(?=<h[23]\b|$)/gi;

  let match: RegExpExecArray | null;

  while ((match = sectionRe.exec(html))) {
    const title = cleanText(match[2]);
    const body = match[3] || "";

    const titleKey = title.toLowerCase();

    if (
      !title ||
      titleKey.includes("references") ||
      titleKey.includes("see also") ||
      titleKey.includes("external links") ||
      titleKey.includes("notes") ||
      titleKey.includes("bibliography")
    ) {
      continue;
    }

    const paragraphs = extractParagraphs(body, 2);

    if (paragraphs.length) {
      sections.push({
        title,
        paragraphs,
      });
    }

    if (sections.length >= 6) break;
  }

  return sections;
}

function pickHighlights(facts: WikiFact[]) {
  const priority = [
    "capital",
    "largest city",
    "official language",
    "population",
    "area",
    "currency",
    "gdp",
    "gross domestic product",
    "gdp rank",
    "inflation",
    "unemployment",
    "exports",
    "imports",
    "revenue",
    "debt",
    "industries",
    "fiscal year",
  ];

  const picked: WikiFact[] = [];
  const used = new Set<string>();

  for (const key of priority) {
    const found = facts.find((fact) => {
      const label = cleanText(fact.label).toLowerCase();
      return label.includes(key) && !used.has(label);
    });

    if (found) {
      picked.push(found);
      used.add(cleanText(found.label).toLowerCase());
    }

    if (picked.length >= 8) break;
  }

  for (const fact of facts) {
    const label = cleanText(fact.label).toLowerCase();
    if (!used.has(label)) {
      picked.push(fact);
      used.add(label);
    }

    if (picked.length >= 8) break;
  }

  return picked;
}

async function fetchFullWikiPage(title: string, group: string): Promise<WikiPagePayload> {
  const summary = await fetchSummary(title);

  let facts: WikiFact[] = [];
  let sections: WikiSection[] = [];

  try {
    const html = await fetchParsedHtml(summary.title || title);
    facts = extractInfoboxFacts(html, group);
    sections = extractSections(html);
  } catch {
    facts = [];
    sections = [];
  }

  return {
    ok: true,
    title: summary.title,
    displayTitle: summary.displayTitle,
    description: summary.description,
    extract: summary.extract,
    pageUrl: summary.pageUrl,
    thumbnailUrl: summary.thumbnailUrl,
    facts,
    highlights: pickHighlights(facts),
    sections,
  };
}

async function fetchDemographics(country: string) {
  const pageTitle = `Demographics of ${country}`;
  const summary = await fetchSummary(pageTitle);

  let paragraphs: string[] = [];

  try {
    const html = await fetchParsedHtml(summary.title || pageTitle);
    paragraphs = extractParagraphs(html, 4);
  } catch {
    paragraphs = [];
  }

  return {
    title: summary.displayTitle || summary.title || pageTitle,
    paragraphs: paragraphs.length ? paragraphs : [summary.extract].filter(Boolean),
  };
}

async function fetchEconomics(country: string) {
  return fetchFullWikiPage(`Economy of ${country}`, "Economy");
}

function responseHeaders() {
  return {
    "Cache-Control": "no-store, no-cache, must-revalidate",
  };
}

export async function GET(req: Request) {
  try {
    const { searchParams } = new URL(req.url);

    const iso3 = cleanText(searchParams.get("iso3")).toUpperCase();
    const countryParam = cleanText(searchParams.get("country"));

    const country =
      countryParam ||
      ISO_TO_COUNTRY[iso3] ||
      cleanText(searchParams.get("name")) ||
      iso3;

    if (!country) {
      return NextResponse.json(
        {
          ok: false,
          error: "Country name or ISO3 code is required.",
        },
        {
          status: 400,
          headers: responseHeaders(),
        },
      );
    }

    const [countryResult, demographicsResult, economicsResult] =
      await Promise.allSettled([
        fetchFullWikiPage(country, "General"),
        fetchDemographics(country),
        fetchEconomics(country),
      ]);

    if (countryResult.status === "rejected") {
      return NextResponse.json(
        {
          ok: false,
          iso3,
          country,
          error:
            countryResult.reason instanceof Error
              ? countryResult.reason.message
              : "Wikipedia country profile unavailable.",
          demographics: null,
          economics: null,
          source: "Wikipedia",
          license: "CC BY-SA 4.0",
          fetchedAt: new Date().toISOString(),
        },
        {
          status: 200,
          headers: responseHeaders(),
        },
      );
    }

    const profile = countryResult.value;

    return NextResponse.json(
      {
        ok: true,
        iso3,
        country,
        title: profile.title,
        displayTitle: profile.displayTitle,
        description: profile.description,
        extract: profile.extract,
        pageUrl: profile.pageUrl,
        thumbnailUrl: profile.thumbnailUrl,
        facts: profile.facts || [],
        highlights: profile.highlights || [],
        demographics:
          demographicsResult.status === "fulfilled"
            ? demographicsResult.value
            : null,
        economics:
          economicsResult.status === "fulfilled"
            ? economicsResult.value
            : {
                ok: false,
                error:
                  economicsResult.reason instanceof Error
                    ? economicsResult.reason.message
                    : "Economy page unavailable.",
              },
        source: "Wikipedia",
        license: "CC BY-SA 4.0",
        fetchedAt: new Date().toISOString(),
        warnings: [
          demographicsResult.status === "rejected"
            ? "Demographics page unavailable"
            : null,
          economicsResult.status === "rejected"
            ? "Economy page unavailable"
            : null,
        ].filter(Boolean),
      },
      {
        status: 200,
        headers: responseHeaders(),
      },
    );
  } catch (error) {
    console.error("Country Wiki API error:", error);

    return NextResponse.json(
      {
        ok: false,
        error:
          error instanceof Error
            ? error.message
            : "Unknown country Wiki API error.",
        demographics: null,
        economics: null,
      },
      {
        status: 500,
        headers: responseHeaders(),
      },
    );
  }
}
